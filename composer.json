{
    "name": "dev1kochi-crypto/sitemap-kit",
    "description": "A reusable Laravel package for automatic sitemap generation.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "dev1kochi-crypto",
            "email": "[EMAIL_ADDRESS]"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0",
        "spatie/laravel-sitemap": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Dev1kochiCrypto\\SitemapKit\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dev1kochiCrypto\\SitemapKit\\SitemapAutomationServiceProvider"
            ]
        }
    }
}